# ═══════════════════════════════════════════════════════════
#  Marketing Intelligence Dashboard — Environment Variables
#  COPY THIS FILE TO .env AND FILL IN YOUR REAL VALUES
#  NEVER commit .env to git (it is already in .gitignore)
# ═══════════════════════════════════════════════════════════

# ── SERVER ───────────────────────────────────────────────
# The full public URL of your deployment (no trailing slash)
# Local dev:  http://localhost:3000
# Production: https://yourdomain.com
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_48_CHARS


# ── GOOGLE OAUTH ─────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
# Create OAuth 2.0 Client ID (Web application)
# Authorized JavaScript Origins: your APP_URL
# Authorized redirect URIs: your APP_URL + /auth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# APIs to enable in your Google Cloud project:
#   - Google Analytics Data API
#   - Google Search Console API
#   - My Business Account Management API
#   - Business Profile Performance API


# ── META APP ─────────────────────────────────────────────
# developers.facebook.com → My Apps → Your App → Basic Settings
# Add product: Facebook Login
# Valid OAuth Redirect URIs: your APP_URL + /auth/meta/callback
# App Domains: your domain
META_APP_ID=000000000000000
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── OPENROUTER AI ────────────────────────────────────────
# openrouter.ai → Keys → Create Key
# Model list: openrouter.ai/models
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-sonnet-4
